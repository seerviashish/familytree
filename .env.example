# Firebase Web config used by the account-deletion page (Auth + Firestore + Storage).
#
# These are NOT secrets: every Firebase web client ships them in its JS bundle, and they
# are safe to expose. Access is gated by the owner-scoped Firestore/Storage security rules
# and by Auth's authorized-domain list — not by hiding these values. They live in env vars
# so project ids aren't hardcoded in the repo and CI can inject them.
#
# Local dev:  copy this file to .env.local and fill in the values.
# CI:         add each one as a GitHub Actions secret
#             (repo → Settings → Secrets and variables → Actions → New repository secret);
#             .github/workflows/deploy.yml passes them to the build.
#
# Values come from: Firebase console → Project settings → Your apps → Web app
#                   → SDK setup and configuration.
#
# The production build FAILS if any of these are missing, so a misconfigured deploy can't
# silently ship a deletion page that doesn't work.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
